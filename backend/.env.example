# ─── Application ─────────────────────────────────
APP_NAME=MedLink UA
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://medlink:medlink_secret@localhost:5432/medlink
DATABASE_URL_SYNC=postgresql://medlink:medlink_secret@localhost:5432/medlink

# ─── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT ──────────────────────────────────────────
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── 2FA ──────────────────────────────────────────
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ─── MinIO ────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_DOCUMENTS=medlink-docs
MINIO_BUCKET_AVATARS=medlink-avatars
MINIO_USE_SSL=False

# ─── Mock ЕСОЗ ────────────────────────────────────
ESOZ_MOCK_URL=http://localhost:8080
ESOZ_CLIENT_ID=medlink_mis_dev
ESOZ_CLIENT_SECRET=mock_esoz_secret_2025
ESOZ_TOKEN_URL=/api/oauth/tokens

# ─── Email (SMTP) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@medlink-ua.com
EMAIL_FROM_NAME=MedLink UA
